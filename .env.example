# ==============================================================================
# vSphere Nexus 环境变量配置文件 (示例)
# ==============================================================================
# 使用说明：
# 1. 复制此文件并重命名为 .env
# 2. 根据您的环境修改以下变量值
# 3. 启动应用：npm start (生产) 或 npm run dev (开发)

# --- 服务器配置 ---
# 后端服务监听端口 (默认: 4173)
PORT=4173

# 运行环境 (production 或 development)
NODE_ENV=development

# --- 安全与跨域 ---
# 允许的跨域来源 (例如: http://localhost:5174)。
# 如果在本地开发且前后端端口不同，请设置此项。生产环境通常由 Nginx/Vite 处理。
CORS_ORIGIN=

# --- VMware 工具配置 ---
# VMware OVF Tool 的可执行文件路径。
# 系统会自动尝试在常见安装目录下检测。如果无法自动找到，请在此处手动指定。
# Windows 示例: C:\Program Files\VMware\VMware OVF Tool\ovftool.exe
# Linux/macOS 示例: /usr/bin/ovftool
OVFTOOL_PATH=
